NODE_ENV=development
APP_NAME=NestJS Template API
APP_DESCRIPTION=Reusable NestJS backend template
APP_VERSION=1.0.0
PORT=3000
CORS_ORIGIN=

# Rate limit
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# Database
DB_ENABLED=false
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=nestjs_template
PG_SCHEMA=
